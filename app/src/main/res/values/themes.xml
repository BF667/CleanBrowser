<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CleanBrowser" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/toolbar_bg</item>
        <item name="colorPrimaryDark">@color/background_dark</item>
        <item name="colorAccent">@color/tab_active</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="UrlBarStyle">
        <item name="android:background">@drawable/url_bar_bg</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="TabItemStyle">
        <item name="android:background">@drawable/tab_item_bg</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>
</resources>